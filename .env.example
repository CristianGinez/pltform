# Database
DATABASE_URL="postgresql://pltform:pltform@localhost:5432/pltform_db"

# JWT
JWT_SECRET=change-this-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=change-this-super-secret-refresh-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth - GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PLATFORM_FEE_PERCENT=10

# Backend
PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# Frontend (Next.js - copy to frontend/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:3001/api
